# Logvault Configuration

# Syslog server settings
syslog:
  host: "0.0.0.0"
  port: 514
  protocol: "udp"
  allowed_ips: [] # Optional list of allowed source IPs/CIDRs for syslog senders, e.g. ["10.0.0.10", "10.0.0.0/24"]

# Redis settings
redis:
  address: "redis:6379" # In Docker Compose, use the Redis service name. When running outside Docker, change this to the appropriate host, e.g. 127.0.0.1:6379
  password: ""
  db: 0

# Web UI settings
web:
  port: 8080
  username: "admin" # Optional legacy single-user login
  secret: "" # Optional legacy single-user secret
  secret_hash: "__ADMIN_SECRET_HASH__" # Replaced during install for the initial admin account
  users:
    - username: "admin"
      secret: "" # Optional legacy plaintext secret
      secret_hash: "__ADMIN_SECRET_HASH__"
      role: "admin"
    - username: "ops"
      secret: ""
      secret_hash: "__OPS_SECRET_HASH__"
      role: "readonly"
  cert_file: "server.crt" # Path to TLS certificate file (e.g., server.crt)
  key_file: "server.key" # Path to TLS key file (e.g., server.key)
  allowed_ips: [] # Optional list of allowed source IPs/CIDRs for the Web UI, e.g. ["10.0.0.10", "10.0.0.0/24"]
  cors_origin: "*" # Set the Access-Control-Allow-Origin header. Use "*" to allow all origins, or specify a single origin like "http://localhost:3000".


# API settings
api:
  bearer_token: "__API_BEARER_TOKEN__" # Generated during install if still unset

# External API integration settings
external_api:
  enabled: false
  url: "http://example.com/api/event"
  method: "POST"
  bearer_token: "" # Optional: Bearer token for external API authentication
  trigger_tags: "ALARM,CRITICAL" # Comma-separated list of syslog tags that trigger the external API call
